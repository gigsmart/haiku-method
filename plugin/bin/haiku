Next steps:`),console.log("  git add .haiku/intents/ && git commit -m 'haiku: migrate intents from .ai-dlc/'"),console.log("  For active intents: run /haiku:run to start from inception"))}var r$=b(()=>{"use strict"});var[ym,...bm]=process.argv.slice(2);if(ym==="mcp")Promise.resolve().then(()=>hS());else if(ym==="hook"){let e=bm[0];e||(console.error("Usage: haiku hook <name>"),process.exit(1)),Promise.resolve().then(()=>(XS(),QS)).then(t=>t.runHook(e,bm.slice(1))).catch(t=>{console.error(`haiku hook ${e}: ${t.message}`),process.exit(1)})}else ym==="migrate"?Promise.resolve().then(()=>(r$(),n$)).then(e=>e.runMigrate(bm)).catch(e=>{console.error(`haiku migrate: ${e.message}`),process.exit(1)}):(console.error("Usage: haiku <mcp|hook|migrate> [args...]"),process.exit(1));
